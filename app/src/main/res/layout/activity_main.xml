<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Android Fundamentals Menu"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnLesson1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Lesson 1: Basic UI &amp; Toast"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnLesson2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Lesson 2: Form Handling"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnLesson3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Lesson 3: Fragments"/>

</LinearLayout>